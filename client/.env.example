# Enhanced Portfolio Management - Environment Configuration

# API Endpoints
VITE_PRICE_INGEST_API_URL=http://localhost:3001/api/prices
VITE_COINGECKO_API_URL=https://api.coingecko.com/api/v3
VITE_UNISWAP_API_URL=http://localhost:3001/api/uniswap-prices

# Smart Contract Addresses (Update after deployment)
VITE_PORTFOLIO_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
VITE_AUTOMATION_CONTROLLER_ADDRESS=0x0000000000000000000000000000000000000000

# Network Configuration
VITE_NETWORK_NAME=reactive-testnet
VITE_CHAIN_ID=1
VITE_RPC_URL=https://rpc.reactive.network

# Testnet Configuration (for simulation mode)
VITE_TESTNET_RPC_URL=https://testnet-rpc.rnk.dev/
VITE_TESTNET_EXPLORER_URL=https://testnet.reactscan.net/
VITE_TESTNET_CHAIN_ID=5318008

# FREACT Token Contract (deployed on Reactive Lasna Testnet)
VITE_FREACT_CONTRACT_ADDRESS=YOUR_FREACT_CONTRACT_ADDRESS_HERE

# Service Configuration
VITE_ENABLE_PRICE_CACHING=true
VITE_PRICE_CACHE_TTL=30000
VITE_PRICE_STALENESS_THRESHOLD=300000

# Rebalancing Configuration
VITE_DEFAULT_DRIFT_THRESHOLD=0.05
VITE_DEFAULT_MAX_GAS_PERCENT=0.02
VITE_DEFAULT_MIN_TRADE_VALUE=10

# Risk Management Configuration
VITE_DEFAULT_TRAILING_STOP_PERCENT=0.05
VITE_DEFAULT_STOP_LOSS_PERCENT=0.10
VITE_PANIC_MODE_TIMEOUT=60000

# Error Handling Configuration
VITE_MAX_RETRIES=3
VITE_BASE_RETRY_DELAY=1000
VITE_ENABLE_HEALTH_CHECKS=true

# Notification Configuration
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_SOUNDS=false
VITE_ENABLE_DESKTOP_NOTIFICATIONS=false
VITE_AUTO_HIDE_DELAY=5000

# Feature Flags
VITE_ENABLE_MANUAL_TRADING=true
VITE_ENABLE_AUTOMATED_TRADING=true
VITE_ENABLE_RISK_MANAGEMENT=true
VITE_ENABLE_PANIC_MODE=true

# Development
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info
