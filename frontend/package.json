{
  "name": "reactive-portfolio-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tailwindcss -i ./src/app.css -o ./src/tw.css --watch & vite dev",
    "build:css": "tailwindcss -i ./src/app.css -o ./src/tw.css --minify",
    "build": "npm run build:css && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "latest",
    "@sveltejs/kit": "latest",
    "@sveltejs/vite-plugin-svelte": "latest",
    "@tailwindcss/forms": "latest",
    "@tailwindcss/typography": "latest",
    "@types/eslint": "latest",
    
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "eslint-plugin-svelte": "latest",
    
    "prettier": "latest",
    "prettier-plugin-svelte": "latest",
    "svelte": "latest",
    "svelte-check": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "dependencies": {
    "ethers": "latest",
    "plotly.js-dist-min": "latest",
    "svelte-french-toast": "latest"
  }
}
