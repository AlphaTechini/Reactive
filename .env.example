# Reactive Network (real or testnet) configuration for frontend & wallet
VITE_REACTIVE_CHAIN_ID=5318007
VITE_REACTIVE_CHAIN_NAME="Reactive Lasna Testnet"
VITE_REACTIVE_SYMBOL=REACT
VITE_REACTIVE_RPC=https://lasna-rpc.rnk.dev/
VITE_REACTIVE_EXPLORER=https://lasna.reactscan.net/

# Toggle mock token / price simulation mode in frontend & services
VITE_USE_MOCK_TOKENS=true
USE_MOCK_TOKENS=true

# Stable token address (USDC or similar) on real network (required when USE_MOCK_TOKENS=false)
# STABLE_TOKEN_ADDRESS=0x...
# Reactive Network Configuration (Testnet)
PRIVATE_KEY=your_testnet_private_key_here_without_0x_prefix
REACTIVE_NETWORK_RPC=https://lasna-rpc.rnk.dev/

# Block Explorer
ETHERSCAN_API_KEY=your_reactive_network_explorer_api_key

# Contract Addresses (will be populated after deployment)
PORTFOLIO_MANAGER_ADDRESS=
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_AUTOMATION_ADDRESS=0x0000000000000000000000000000000000000000

# Webhook Service Configuration (Mock Trading)
WEBHOOK_PORT=3001
VITE_WEBHOOK_URL=http://localhost:3001/api

# Network Configuration (Legacy - use VITE_REACTIVE_* above)
VITE_NETWORK_NAME=Reactive Lasna Testnet
VITE_CHAIN_ID=5318007
VITE_RPC_URL=https://lasna-rpc.rnk.dev/
VITE_EXPLORER_URL=https://lasna.reactscan.net/

# Mock Trading Configuration
VITE_MOCK_TRADING=true
VITE_PRICE_UPDATE_INTERVAL=30000
VITE_TRIGGER_CHECK_INTERVAL=60000

# Development
NODE_ENV=development
